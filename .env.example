MAIL_API_PORT=8787
MAIL_API_ALLOWED_ORIGIN=http://localhost:5173,capacitor://localhost

# IONOS defaults. Keep secrets in .env only; never put them in src/.
MAIL_IMAP_HOST=imap.ionos.com
MAIL_IMAP_PORT=993
MAIL_IMAP_SECURE=true
MAIL_SMTP_HOST=smtp.ionos.com
MAIL_SMTP_PORT=465
MAIL_SMTP_SECURE=true

MAIL_USER=you@yourdomain.com
MAIL_PASSWORD=your-mailbox-password-or-app-password
MAIL_FROM_NAME=Mail App

# Optional provider-specific folder names.
MAIL_FOLDER_INBOX=INBOX
MAIL_FOLDER_SENT=Sent
MAIL_FOLDER_DRAFTS=Drafts
MAIL_FOLDER_SPAM=Spam
MAIL_FOLDER_TRASH=Trash
MAIL_FOLDER_ARCHIVE=Archive

# Frontend setting. For iPhone testing, use your Mac LAN IP instead of localhost,
# for example: VITE_MAIL_API_URL=http://192.168.1.50:8787
VITE_MAIL_API_URL=http://localhost:8787
